{
    "minify": true,
    "jsc": {
        "minify": {
            "compress": true
        },
        "parser": {
            "syntax": "ecmascript",
            "jsx": true,
            "decorators": true
        },
        "transform": {
            "react": {
                "pragma": "alorin.createElement",
                "pragmaFrag": "alorin.wrapper",
                "refresh": true
            }
        },
        "target": "esnext",
        "preserveAllComments": false
    },
    "module": {
        "type": "es6",
        "strict": true
    }
}