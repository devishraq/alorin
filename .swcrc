{
    "minify": true,
    "jsc": {
        "minify": {
            "compress": true // equivalent to {}
        },
        "parser": {
            "syntax": "ecmascript",
            "jsx": true,
            "decorators": true
        },
        "transform": {
            "react": {
                "pragma": "olka.createElement",
                "pragmaFrag": "olka.wrapper"
            }
        },
        "target": "es2016",
        "preserveAllComments": false
    },
    "module": {
        "type": "es6",
        "strict": true
    }
}