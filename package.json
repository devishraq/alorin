		"js-framework-for-begginers"
	],
	"author": "Ishraq Tanvir",
	"license": "ISC",
	"devDependencies": {
		"@swc/cli": "^0.3.12",
		"@swc/core": "^1.6.13",
		"@swc/jest": "^0.2.36",
		"@testing-library/jest-dom": "^6.4.6",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0"
	},
	"dependencies": {
		"chokidar": "^3.6.0",
		"lodash": "^4.17.21",
		"nanoid": "^5.0.7"
	},
	"@parcel/transformer-css": {
		"cssModules": true
	}
