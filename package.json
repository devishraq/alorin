{
	"name": "alorin",
	"version": "0.1",
	"description": "Alorin is a high level super reactive js framerwork focused on performance and simplicity.",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"compiler": "npx swc src -d dist --watch",
		"server": "parcel ./src/index.html",
